<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:label="MPESA Tracker"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:supportsRtl="true">

        <!-- ===== LSPosed / Xposed module metadata ===== -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <meta-data
            android:name="xposeddescription"
            android:value="Tracks M-PESA SMS, parses txn data, posts to n8n webhook." />

        <!-- Minimum Xposed API version (82 = stable LSPosed) -->
        <meta-data
            android:name="xposedminversion"
            android:value="82" />

        <!-- Default scope hint (LSPosed reads this; user still confirms in Manager) -->
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

        <!-- Woken by the SMS hook (host process) to post the categorize
             notification AS THIS app. Exported so the host broadcast reaches it. -->
        <receiver
            android:name=".ShowCategoryReceiver"
            android:exported="true">
            <!-- intent-filter grants the host app package visibility of u
                 (Android 11+ AppsFilter), so its broadcast actually resolves. -->
            <intent-filter>
                <action android:name="com.blyator.mpesa.action.SHOW_CATEGORIES" />
            </intent-filter>
        </receiver>

        <!-- Category button taps. Not exported — only our own PendingIntents. -->
        <receiver
            android:name=".CategoryActionReceiver"
            android:exported="false" />

        <!-- Woken by host process when n8n POST fails offline; enqueues WorkManager retry. -->
        <receiver
            android:name=".QueueReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.blyator.mpesa.action.QUEUE_TXN" />
            </intent-filter>
        </receiver>

        <!-- Foreground service that does the category POST with network access
             even when the app's background process is otherwise restricted. -->
        <service
            android:name=".CategoryPostService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

    </application>

</manifest>
